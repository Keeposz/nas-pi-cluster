{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard"
  ],
  "timezone": "Europe/Brussels",
  "schedule": [
    "before 5am on sunday"
  ],
  "labels": [
    "dependencies"
  ],
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "description": "Skip floating :latest tags (we want to stay on latest by restarting pods)",
      "matchManagers": [
        "kubernetes"
      ],
      "matchCurrentValue": "/^latest$/",
      "enabled": false
    },
    {
      "description": "Group all Helm chart updates per app into a single PR",
      "matchManagers": [
        "helmv3"
      ],
      "groupName": "{{depName}} chart"
    }
  ]
}
